<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_secondary"
    tools:context=".PinFragment">

    <TextView
        android:id="@+id/txt_pin_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:fontFamily="@font/poppins_black"
        android:text="Masukkan PIN Anda"
        android:textColor="@color/green"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_pin_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Keamanan adalah prioritas kami"
        android:textColor="@color/brown"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_pin_title" />

    <LinearLayout
        android:id="@+id/layout_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_pin_hint">

        <ImageView
            android:id="@+id/dot1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/btn_radio"
            app:tint="@color/brown"
            android:alpha="0.3" />

        <ImageView
            android:id="@+id/dot2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/btn_radio"
            app:tint="@color/brown"
            android:alpha="0.3" />

        <ImageView
            android:id="@+id/dot3"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/btn_radio"
            app:tint="@color/brown"
            android:alpha="0.3" />

        <ImageView
            android:id="@+id/dot4"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/btn_radio"
            app:tint="@color/brown"
            android:alpha="0.3" />
    </LinearLayout>

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Buttons 1-9 -->
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_1" android:layout_width="80dp" android:layout_height="80dp" android:text="1" android:textSize="24sp" android:textColor="@color/green" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_2" android:layout_width="80dp" android:layout_height="80dp" android:text="2" android:textSize="24sp" android:textColor="@color/green" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_3" android:layout_width="80dp" android:layout_height="80dp" android:text="3" android:textSize="24sp" android:textColor="@color/green" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_4" android:layout_width="80dp" android:layout_height="80dp" android:text="4" android:textSize="24sp" android:textColor="@color/green" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_5" android:layout_width="80dp" android:layout_height="80dp" android:text="5" android:textSize="24sp" android:textColor="@color/green" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_6" android:layout_width="80dp" android:layout_height="80dp" android:text="6" android:textSize="24sp" android:textColor="@color/green" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_7" android:layout_width="80dp" android:layout_height="80dp" android:text="7" android:textSize="24sp" android:textColor="@color/green" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_8" android:layout_width="80dp" android:layout_height="80dp" android:text="8" android:textSize="24sp" android:textColor="@color/green" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_9" android:layout_width="80dp" android:layout_height="80dp" android:text="9" android:textSize="24sp" android:textColor="@color/green" />

        <!-- Empty, 0, Backspace -->
        <View android:layout_width="80dp" android:layout_height="80dp" />
        <Button style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_0" android:layout_width="80dp" android:layout_height="80dp" android:text="0" android:textSize="24sp" android:textColor="@color/green" />
        <ImageButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn_backspace" android:layout_width="80dp" android:layout_height="80dp" android:src="@android:drawable/ic_input_delete" app:tint="@color/green" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
